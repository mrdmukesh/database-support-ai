# Copy this file to .env for local development only.
# Do not put real production secrets in Git.

APP_ENV=development
DATABASE_URL=sqlite:///./local.db
JWT_SECRET=change-this-locally
JWT_ACCESS_TOKEN_MINUTES=60
SESSION_TIMEOUT_MINUTES=60
UPLOAD_MAX_SIZE_BYTES=26214400
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=app-artifacts
SENTRY_DSN=

# Optional evidence-grounded LLM reasoning.
AI_REASONING_ENABLED=false
LLM_ENABLED=false
VERIFICATION_AGENT_ENABLED=true
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Knowledge retriever backend: sqlite, qdrant, or pgvector.
KNOWLEDGE_RETRIEVER_BACKEND=sqlite

# Phase 1 enterprise security foundation.
FEATURE_ENTERPRISE_RBAC_ENABLED=false
FEATURE_AUDIT_LOGGING_ENABLED=true
FEATURE_KEYVAULT_SECRETS_ENABLED=false
AZURE_KEY_VAULT_URL=
