# Evaluation result persistence (never point this at an application production database)
DATABASE_URL=postgresql+psycopg://<evaluation_user>:<password>@<evaluation_results_host>:5432/<evaluation_results_database>

# Synthetic SQL Server databases: destructive evaluation-runner credentials only
EVAL_SQL_SERVER=<evaluation_sql_host>,1433
EVAL_SQL_ADMIN=<evaluation_runner_login>
EVAL_SQL_PASSWORD=<evaluation_runner_password>
EVAL_ALLOWED_SQL_HOSTS=<evaluation_sql_host>
EVAL_ALLOWED_DATABASES=EvalPayroll,EvalClinic,EvalOrders,EvalBanking,EvalShipping
EVAL_APPLICATION_DB_ACCESS_MODE=read_only

# Public application API and test identity
EVAL_API_BASE_URL=http://127.0.0.1:8000
EVAL_ACCESS_TOKEN=<test_user_bearer_token>
EVAL_ORGANIZATION_ID=<evaluation_organization_id>
EVAL_WORKSPACE_ID=<evaluation_workspace_id>
EVAL_USER_ID=<evaluation_user_id>
EVAL_CONNECTION_ID_PAYROLL=<read_only_payroll_connection_id>
EVAL_CONNECTION_ID_CLINIC=<read_only_clinic_connection_id>
EVAL_CONNECTION_ID_ORDERS=<read_only_orders_connection_id>
EVAL_CONNECTION_ID_BANKING=<read_only_banking_connection_id>
EVAL_CONNECTION_ID_SHIPPING=<read_only_shipping_connection_id>

# Secondary semantic judge
OPENAI_API_KEY=<judge_api_key>
EVAL_JUDGE_PROVIDER=openai
EVAL_JUDGE_MODEL=<primary_judge_model>
EVAL_SECOND_JUDGE_MODEL=
EVAL_JUDGE_INPUT_COST_PER_MILLION=<usd_per_million_input_tokens>
EVAL_JUDGE_OUTPUT_COST_PER_MILLION=<usd_per_million_output_tokens>

# Bounded execution and retries
EVAL_POLL_INTERVAL_SECONDS=2
EVAL_SCENARIO_TIMEOUT_SECONDS=300
EVAL_API_MAX_RETRIES=3
EVAL_JUDGE_TIMEOUT_SECONDS=90
EVAL_JUDGE_MAX_RETRIES=2
EVAL_JUDGE_RETRY_BACKOFF_SECONDS=1
EVAL_HUMAN_REVIEW_SAMPLE_RATE=0
EVAL_HUMAN_REVIEW_SAMPLE_SEED=pilot-v1

# Artifacts and the fixed five-domain smoke selection
EVAL_ARTIFACT_ROOT=research/results
EVAL_SMOKE_SCENARIO_PAYROLL=payroll-pilot-001
EVAL_SMOKE_SCENARIO_CLINIC=clinic-pilot-001
EVAL_SMOKE_SCENARIO_ORDERS=orders-pilot-001
EVAL_SMOKE_SCENARIO_BANKING=banking-pilot-001
EVAL_SMOKE_SCENARIO_SHIPPING=shipping-pilot-001
